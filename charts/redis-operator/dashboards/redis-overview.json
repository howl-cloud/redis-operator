{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Healthy Instances",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(redis_up{namespace=~\"$namespace\",cluster=~\"$cluster\"} == 1)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Unhealthy Instances",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(redis_up{namespace=~\"$namespace\",cluster=~\"$cluster\"} == 0)",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Desired Instances",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(redis_cluster_instances_total{namespace=~\"$namespace\",cluster=~\"$cluster\",type=\"desired\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Current Primaries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(redis_up{namespace=~\"$namespace\",cluster=~\"$cluster\",role=\"master\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cluster Phase",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "redis_cluster_phase{namespace=~\"$namespace\",cluster=~\"$cluster\"}",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Replication Lag (Bytes)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "redis_replication_lag_bytes{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\",role=\"slave\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Connected Replicas",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 14
      },
      "targets": [
        {
          "expr": "redis_connected_replicas{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\",role=\"master\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Master Link Up",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 14
      },
      "targets": [
        {
          "expr": "redis_master_link_up{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\",role=\"slave\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Memory Usage Ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "expr": "redis_used_memory_bytes{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"} / clamp_min(redis_maxmemory_bytes{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"}, 1)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Evictions / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 22
      },
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"}[5m])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Fragmentation Ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 22
      },
      "targets": [
        {
          "expr": "redis_mem_fragmentation_ratio{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Connected Clients",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "expr": "redis_connected_clients{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Blocked Clients",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 30
      },
      "targets": [
        {
          "expr": "redis_blocked_clients{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Rejected Connections / sec",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 30
      },
      "targets": [
        {
          "expr": "rate(redis_rejected_connections_total{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"}[5m])",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Ops / sec by Command (GET/SET/DEL)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 38
      },
      "targets": [
        {
          "expr": "sum by (command) (rate(redis_command_calls_total{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\",command=~\"get|set|del\"}[5m]))",
          "legendFormat": "{{command}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Keyspace Hit Ratio",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 38
      },
      "targets": [
        {
          "expr": "sum(rate(redis_keyspace_hits_total{namespace=~\"$namespace\",cluster=~\"$cluster\"}[5m])) / clamp_min(sum(rate(redis_keyspace_hits_total{namespace=~\"$namespace\",cluster=~\"$cluster\"}[5m])) + sum(rate(redis_keyspace_misses_total{namespace=~\"$namespace\",cluster=~\"$cluster\"}[5m])), 1)",
          "legendFormat": "hit_ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "RDB Last Save Duration (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 46
      },
      "targets": [
        {
          "expr": "redis_rdb_last_bgsave_duration_seconds{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "AOF Last Rewrite Duration (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 46
      },
      "targets": [
        {
          "expr": "redis_aof_last_rewrite_duration_seconds{namespace=~\"$namespace\",cluster=~\"$cluster\",pod=~\"$pod\"}",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Last Successful Backup Time",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 46
      },
      "targets": [
        {
          "expr": "max(redis_last_successful_backup_timestamp{namespace=~\"$namespace\",cluster=~\"$cluster\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value",
        "colorMode": "value"
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Backup Phase Counts",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 54
      },
      "targets": [
        {
          "expr": "redis_backup_phase_count{namespace=~\"$namespace\",cluster=~\"$cluster\"}",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Last Successful Backup Age (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 54
      },
      "targets": [
        {
          "expr": "time() - max(redis_last_successful_backup_timestamp{namespace=~\"$namespace\",cluster=~\"$cluster\"})",
          "legendFormat": "age_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "redis",
    "operator",
    "prometheus"
  ],
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(redis_up, namespace)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "cluster",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(redis_up{namespace=~\"$namespace\"}, cluster)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(redis_up{namespace=~\"$namespace\",cluster=~\"$cluster\"}, pod)",
        "refresh": 2,
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "Redis Operator Overview",
  "uid": "redis-operator-overview",
  "version": 2,
  "weekStart": ""
}
